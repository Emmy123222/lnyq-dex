{
  "name": "lnyq-api-server",
  "version": "2.0.0",
  "description": "LNYQ DEX API server — real CLOB engine backed by PostgreSQL",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "db:generate": "prisma generate && touch node_modules/.prisma/client/index.d.ts",
    "db:migrate": "prisma migrate dev && touch node_modules/.prisma/client/index.d.ts",
    "db:push": "prisma db push && touch node_modules/.prisma/client/index.d.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^11.0.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "prisma": "^5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  }
}
