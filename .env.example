# ─────────────────────────────────────────────────────────────────────────────
# LNYQ Environment Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# App mode: local-api | devnet-api | staging | production
# local-api: hits the local sim server (npm run sim in server/)
# devnet-api: hits a deployed devnet backend
# There is NO mock mode. Every mode hits a real backend.
VITE_LNYQ_ENV=local-api

# Target chain
# Options: solana-devnet | arbitrum-sepolia | arbitrum-mainnet
VITE_LNYQ_CHAIN=solana-devnet

# Backend REST API base URL (required)
# local-api example: http://localhost:3001/api
# devnet example:    https://api.devnet.lnyq.xyz/api
VITE_LNYQ_API_URL=http://localhost:3001/api

# Backend WebSocket URL (required for live order book / trades)
# local-api example: ws://localhost:3002
VITE_LNYQ_WS_URL=ws://localhost:3002

# RPC URL for the target chain (required for wallet interactions)
VITE_LNYQ_RPC_URL=

# ── Squid Router (Phase 3 only) ───────────────────────────────────────────────
VITE_SQUID_BASE_URL=https://apiplus.squidrouter.com
VITE_SQUID_INTEGRATOR_ID=

# Squid capability flags — false until Squid confirms support for your integrator ID
VITE_SQUID_ENABLE_CORAL=false
VITE_SQUID_ENABLE_COLLECT_FEES=false
VITE_SQUID_ENABLE_SOLANA_BTC=false

# ── Product feature gates ─────────────────────────────────────────────────────
# Phase 1: spot CLOB only — all of the below stay false

# Phase 2 — perpetual markets and leverage controls
VITE_ENABLE_PERPS=false

# Phase 3 — cross-chain USDC deposits/withdrawals via Squid
VITE_ENABLE_CROSS_CHAIN=false

# Phase 3 — presale / launchpad mechanics
VITE_ENABLE_PRESALE=false
